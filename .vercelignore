# Vercel ignore file
# Files that should not be deployed to Vercel

# Development files
.env
.env.local
.env.*.local

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Git files
.git/
.gitignore
.gitattributes

# Documentation (not needed in production)
docs/
*.md
!README.md

# Test files
__tests__/
*.test.js
*.spec.js
jest.config.js
jest.setup.js

# Build tools
vite.config.js
.eslintrc.json
.prettierrc
.editorconfig

# Scripts
install-windows.bat

# Verification
verify.html
VERIFICATION_COMPLETE.md
TRANSFORMATION_REPORT.md

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage
coverage/
.nyc_output/

# Temporary
.tmp/
temp/
*.tmp
*.temp
