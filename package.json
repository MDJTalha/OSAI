{
  "name": "osai-enterprise-vision",
  "version": "8.0.0",
  "description": "OSAI - Enterprise AI Vision System with AR Measurement and Object Detection",
  "main": "app.js",
  "scripts": {
    "start": "http-server -p 8080 -c-1",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "dev": "vite",
    "analyze": "vite-bundle-visualizer",
    "security-audit": "npm audit",
    "prepare": "husky install"
  },
  "keywords": [
    "computer-vision",
    "object-detection",
    "augmented-reality",
    "measurement",
    "ai",
    "machine-learning",
    "tensorflow-js",
    "opencv",
    "pwa",
    "enterprise"
  ],
  "author": "OSAI Team",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^5.1.3",
    "http-server": "^14.1.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "jest-sonar-reporter": "^2.0.0",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-bundle-visualizer": "^1.0.0",
    "workbox-cli": "^7.0.0"
  },
  "dependencies": {
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow-models/mobilenet": "^2.1.1",
    "@tensorflow/tfjs": "^4.17.0",
    "jsqr": "^1.4.0",
    "tesseract.js": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    ">1%",
    "last 2 versions",
    "not dead",
    "not IE 11"
  ],
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "jest --findRelatedTests --bail"
    ]
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "junit.xml"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/osai/enterprise-vision.git"
  },
  "bugs": {
    "url": "https://github.com/osai/enterprise-vision/issues"
  },
  "homepage": "https://github.com/osai/enterprise-vision#readme"
}
